{
  "name": "driveflow-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "install-all": "npm install",
    "dev:backend": "npm run dev -w @driveflow/backend",
    "dev:web": "npm run dev -w @driveflow/web-app",
    "build:shared": "npm run build -w @driveflow/shared",
    "db:generate": "npm run db:generate -w @driveflow/backend",
    "db:migrate": "npm run db:migrate -w @driveflow/backend",
    "db:reset": "npm run db:reset -w @driveflow/backend",
    "db:seed": "tsx --env-file=.env ./apps/backend/prisma/seed.ts"
  }
}