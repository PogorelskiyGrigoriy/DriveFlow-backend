generator client {
  provider = "prisma-client-js"
}

generator zod {
  provider = "zod-prisma-types"
  output   = "../../../packages/shared/src/generated/zod"
}

datasource db {
  provider = "postgresql"
}

// --- Enums ---

enum Role {
  OWNER
  ADMIN
  INSTRUCTOR
  STUDENT
}

enum LessonStatus {
  PLANNED
  COMPLETED
  CANCELLED
  NO_SHOW
}

// --- Models ---

model School {
  id             String   @id @default(uuid())
  name           String
  address        String?
  // Basic configuration for time-slot calculations
  lessonDuration Int      @default(45) 
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  users   User[]
  lessons Lesson[]
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(STUDENT)
  firstName    String
  lastName     String
  phoneNumber  String   @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  instructorProfile InstructorProfile?
  studentProfile    StudentProfile?
}

model InstructorProfile {
  id                String   @id @default(uuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  licenseCategories String[]

  // Working hours and slot management
  availability Availability[]
  lessons      Lesson[]
  students     StudentProfile[]
}

model StudentProfile {
  id           String   @id @default(uuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Direct link to assigned instructor
  instructorId String
  instructor   InstructorProfile @relation(fields: [instructorId], references: [id])

  totalLessons Int @default(0)
  balance      Int @default(0)

  lessons Lesson[]
}

model Lesson {
  id        String       @id @default(uuid())
  // Specific date and time for the booking
  startTime DateTime
  endTime   DateTime
  status    LessonStatus @default(PLANNED)

  // Pickup/Dropoff locations (optional)
  locationStart String?
  locationEnd   String?

  schoolId     String
  school       School @relation(fields: [schoolId], references: [id])
  
  instructorId String
  instructor   InstructorProfile @relation(fields: [instructorId], references: [id])
  
  studentId    String
  student      StudentProfile @relation(fields: [studentId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Prevent overlapping bookings and optimize availability search
  @@index([instructorId, startTime, endTime])
}

model Availability {
  id           String @id @default(uuid())
  instructorId String
  instructor   InstructorProfile @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  // Recurring weekly schedule
  dayOfWeek Int    // 0-6 (Sunday to Saturday)
  startTime String // Format: "HH:mm"
  endTime   String // Format: "HH:mm"

  @@unique([instructorId, dayOfWeek, startTime, endTime])
}