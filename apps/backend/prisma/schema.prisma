generator client {
  provider = "prisma-client-js"
}

generator zod {
  provider = "zod-prisma-types"
  output   = "../../../packages/shared/src/generated/zod"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  INSTRUCTOR
  STUDENT
}

enum LessonStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

model User {
  id           String   @id @default(uuid())
  phoneNumber  String   @unique // Главный идентификатор в Израиле (+972...)
  firstName    String
  lastName     String
  role         Role     @default(STUDENT)
  createdAt    DateTime @default(now())

  // Связь "Учитель -> Ученики" (Self-relation)
  // Ученик привязан к одному учителю. У учителя много учеников.
  instructorId String?
  instructor   User?    @relation("InstructorStudents", fields: [instructorId], references: [id])
  students     User[]   @relation("InstructorStudents")

  // Связи с уроками
  lessonsAsInstructor Lesson[] @relation("InstructorLessons")
  lessonsAsStudent    Lesson[] @relation("StudentLessons")

  // Настройки рабочего времени (только для роли INSTRUCTOR)
  availabilities      InstructorAvailability[]

  // Токены для беспарольного входа (Magic Links) через SMS/WhatsApp
  magicTokens         MagicToken[]
}

model InstructorAvailability {
  id           String @id @default(uuid())
  instructorId String
  instructor   User   @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  // 0 = Воскресенье (Йом Ришон — начало недели в Израиле), 1 = Понедельник ... 6 = Суббота
  dayOfWeek    Int    
  startHour    Int    // Час начала работы (например, 8 означает 08:00)
  endHour      Int    // Час окончания работы (например, 17 означает 17:00)

  @@unique([instructorId, dayOfWeek]) // Один график на один день недели для конкретного учителя
}

model Lesson {
  id           String       @id @default(uuid())
  instructorId String
  instructor   User         @relation("InstructorLessons", fields: [instructorId], references: [id])
  studentId    String
  student      User         @relation("StudentLessons", fields: [studentId], references: [id])

  // Дата и время начала урока.
  // Логика бэкенда будет гарантировать запись на начало часа (например, 10:00:00)
  startTime    DateTime
  
  // Длительность урока в минутах. По твоему условию дефолт — 1 час (60 минут)
  durationMin  Int          @default(60) 
  
  status       LessonStatus @default(SCHEDULED)
  createdAt    DateTime     @default(now())

  // Защита на уровне БД: учитель не может физически забронировать два урока на одно и то же время
  @@unique([instructorId, startTime]) 
}

model MagicToken {
  id        String   @id @default(uuid())
  token     String   @unique @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}