generator client {
  provider = "prisma-client-js"
}

generator zod {
  provider = "zod-prisma-types"
  output   = "../../../packages/shared/src/generated/zod" // Путь к shared слою в монорепозитории
}

datasource db {
  provider = "postgresql"
}

enum Role {
  OWNER
  INSTRUCTOR
  STUDENT
}

enum LessonStatus {
  PLANNED
  COMPLETED
  CANCELLED
  NO_SHOW
}

// --- Модели ---

model School {
  id             String   @id @default(uuid())
  name           String
  address        String?
  // Требование владельца: CRUD по настройкам школы
  lessonDuration Int      @default(45) 
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  users   User[]
  lessons Lesson[]
  cars    Car[]
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(STUDENT)
  firstName    String
  lastName     String
  phoneNumber  String?  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  // Связи для расширенных профилей (CRUD владельца)
  instructorProfile InstructorProfile?
  studentProfile    StudentProfile?
}

model InstructorProfile {
  id                String   @id @default(uuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  licenseCategories String[]
  experienceYears   Int?
  bio               String?

  // Для водителя: назначение доступного времени
  availability Availability[]
  // Для водителя: просмотр своих уроков
  lessons      Lesson[]
  // Для ученика: привязка к конкретному учителю
  students     StudentProfile[]
}

model StudentProfile {
  id           String   @id @default(uuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Ученик привязан к одному учителю изначально
  instructorId String
  instructor   InstructorProfile @relation(fields: [instructorId], references: [id])

  totalLessons Int @default(0)
  balance      Int @default(0) // Оплаченные уроки

  lessons Lesson[]
}

model Car {
  id            String  @id @default(uuid())
  model         String
  plateNumber   String  @unique
  lastOdometer  Int     @default(0)
  isManual      Boolean @default(true)

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])
  lessons  Lesson[]
}

model Lesson {
  id        String       @id @default(uuid())
  startTime DateTime
  endTime   DateTime
  status    LessonStatus @default(PLANNED)

  // Опционально: откуда забрать и куда высадить
  locationStart String?
  locationEnd   String?

  schoolId     String
  school       School @relation(fields: [schoolId], references: [id])
  
  instructorId String
  instructor   InstructorProfile @relation(fields: [instructorId], references: [id])
  
  studentId    String
  student      StudentProfile @relation(fields: [studentId], references: [id])
  
  carId        String
  car          Car @relation(fields: [carId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Индекс для защиты от накладок и быстрого поиска свободных окон
  @@index([instructorId, startTime, endTime])
}

model Availability {
  id           String @id @default(uuid())
  instructorId String
  instructor   InstructorProfile @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  dayOfWeek Int // 0-6 (Воскресенье - Суббота)
  startTime String // Формат "HH:mm"
  endTime   String // Формат "HH:mm"

  @@unique([instructorId, dayOfWeek, startTime, endTime])
}