// documentation: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Enums ---

enum Role {
  OWNER
  INSTRUCTOR
  STUDENT
}

enum LessonStatus {
  PLANNED
  COMPLETED
  CANCELLED
}

// --- Models ---

model School {
  id             String   @id @default(uuid())
  name           String
  address        String?
  lessonDuration Int      @default(45)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  users   User[]
  lessons Lesson[]
  cars    Car[]
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(STUDENT)
  firstName    String
  lastName     String
  phoneNumber  String?  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  instructorProfile InstructorProfile?
  studentProfile    StudentProfile?
}

model InstructorProfile {
  id                String   @id @default(uuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  licenseCategories String[]
  experienceYears   Int?
  bio               String?

  availability Availability[]
  lessons      Lesson[]
  students     StudentProfile[]
}

model StudentProfile {
  id           String   @id @default(uuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  instructorId String
  instructor   InstructorProfile @relation(fields: [instructorId], references: [id])

  totalLessons Int @default(0)
  balance      Int @default(0)

  lessons Lesson[]
}

model Car {
  id            String  @id @default(uuid())
  model         String
  plateNumber   String  @unique
  lastOdometer  Int     @default(0)
  isManual      Boolean @default(true)

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])
  lessons  Lesson[]
}

model Lesson {
  id        String       @id @default(uuid())
  startTime DateTime
  endTime   DateTime
  status    LessonStatus @default(PLANNED)

  locationStart String?
  locationEnd   String?

  odometerStart Int?
  odometerEnd   Int?
  fuelLevelStart Float?
  fuelLevelEnd   Float?

  schoolId     String
  school       School @relation(fields: [schoolId], references: [id])
  
  instructorId String
  instructor   InstructorProfile @relation(fields: [instructorId], references: [id])
  
  studentId    String
  student      StudentProfile @relation(fields: [studentId], references: [id])
  
  carId        String
  car          Car @relation(fields: [carId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([instructorId, startTime, endTime])
}

model Availability {
  id           String @id @default(uuid())
  instructorId String
  instructor   InstructorProfile @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  dayOfWeek Int
  startTime String 
  endTime   String 

  @@unique([instructorId, dayOfWeek, startTime, endTime])
}